# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/bug-tracker

# JWT (RS256 keys)
# Option 1: Set as environment variables
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Option 2: Use key files (jwtRS256.key / jwtRS256.key.pub in project root)
# Config auto-falls back to file read if env vars are not set
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Sentry (error monitoring)
SENTRY_DSN=https://key@sentry.io/project

# Gemini AI (replaces OpenAI)
GEMINI_API_KEY=your-gemini-api-key

# Encryption key for sensitive data (GitHub tokens, etc.)
# If not set, JWT_PRIVATE_KEY is used as fallback
ENCRYPTION_KEY=your-encryption-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Client URL
CLIENT_URL=http://localhost:5173

# Vite API URL (for Socket.io - leave empty to use Vite proxy)
# VITE_API_URL=http://localhost:5000
